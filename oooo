];

// STATE
let currentCards=[],currentCard=0,quizIndex=0,score=0,shuffledQuiz=[],tlFilter='all';

// NAV
function showSection(id){
  ['menu','flashcards','quiz','frise'].forEach(s=>document.getElementById(s).classList.add('hidden'));
  document.getElementById(id).classList.remove('hidden');
  document.querySelectorAll('.nav-btn').forEach((b,i)=>{
    b.classList.remove('active');
    if(['menu','flashcards','quiz','frise'][i]===id)b.classList.add('active');
  });
  if(id==='frise')buildTimeline();
}

// UTILS
function shuffle(arr){const a=[...arr];for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}

// FLASHCARDS
function startFlash(cat){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  const cats=['all','dates','notions','acteurs','social','rural'];
  const idx=cats.indexOf(cat);
  if(idx>=0)document.querySelectorAll('.tab')[idx].classList.add('active');
  currentCards=cat==='all'?shuffle(allCards):shuffle(allCards.filter(c=>c.cat===cat));
  currentCard=0;
  document.getElementById('flashCard').classList.remove('flip');
  showCard();
}
function showCard(){
  if(!currentCards.length)return;
  const c=currentCards[currentCard];
  document.getElementById('question').innerText=c.q;
  document.getElementById('answer').innerText=c.a;
  document.getElementById('cardCounter').innerText=(currentCard+1)+' / '+currentCards.length;
  const badges={dates:'📅 Date',notions:'📖 Notion',acteurs:'👤 Acteur',social:'⚖️ Social',rural:'🌾 Rural'};
  document.getElementById('catBadge').innerText=badges[c.cat]||'';
}
function flipCard(){document.getElementById('flashCard').classList.toggle('flip');}
function nextCard(){document.getElementById('flashCard').classList.remove('flip');currentCard=(currentCard+1)%currentCards.length;showCard();}
function prevCard(){document.getElementById('flashCard').classList.remove('flip');currentCard=(currentCard-1+currentCards.length)%currentCards.length;showCard();}

// QUIZ
function startQuiz(){shuffledQuiz=shuffle(quizData);quizIndex=0;score=0;updateProgress();showQuiz();}
function updateProgress(){
  document.getElementById('progress').style.width=(quizIndex/shuffledQuiz.length*100)+'%';
  const el=document.getElementById('quizNum');
  if(el&&quizIndex<shuffledQuiz.length)el.innerText='Question '+(quizIndex+1)+' / '+shuffledQuiz.length;
}
function showQuiz(){
  if(quizIndex>=shuffledQuiz.length){showResult();return;}
  const q=shuffledQuiz[quizIndex];
  const sa=shuffle(q.answers);
  let html=`<div class="quiz-card"><p class="quiz-q">${q.q}</p>`;
  sa.forEach(a=>{
    const e=a.replace(/'/g,"\\'");
    const ce=q.correct.replace(/'/g,"\\'");
    html+=`<button class="ans-btn" onclick="checkAnswer(this,'${e}','${ce}')">${a}</button>`;
  });
  html+=`</div>`;
  document.getElementById('quizContent').innerHTML=html;
}
function checkAnswer(btn,chosen,correct){
  document.querySelectorAll('.ans-btn').forEach(b=>{b.disabled=true;if(b.innerText===correct)b.classList.add('correct');});
  if(chosen===correct){btn.classList.add('correct');score++;}
  else btn.classList.add('wrong');
  setTimeout(()=>{quizIndex++;updateProgress();showQuiz();},950);
}
function showResult(){
  const note=(score/shuffledQuiz.length*20).toFixed(1);
  const n=parseFloat(note);
  const niveau=n>=16?"Excellent 🎓":n>=12?"Bon niveau 👍":n>=8?"Niveau moyen 📖":"À retravailler 📚";
  document.getElementById('quizNum').innerText='';
  document.getElementById('quizContent').innerHTML=`
    <div class="result-box">
      <div style="font-size:44px;margin-bottom:10px">🏆</div>
      <div class="result-score">${note}<span style="font-size:24px">/20</span></div>
      <div class="result-label">${niveau}</div>
      <div class="result-sub">${score} bonnes réponses sur ${shuffledQuiz.length}</div>
      <div class="pill-row" style="justify-content:center;margin-top:4px">
        <button class="pill primary" onclick="startQuiz()">Recommencer</button>
        <button class="pill" onclick="showSection('menu')">Menu</button>
      </div>
    </div>`;
  document.getElementById('progress').style.width='100%';
}

// TIMELINE
const tagLabels={eco:'💰 Éco',social:'⚖️ Social',transport:'🚂 Transport',politique:'🏛️ Politique'};
function buildTimeline(){
  const fd=document.getElementById('tlFilter');
  fd.innerHTML='';
  const tags=['all','eco','social','transport'];
  const labels={all:'Tout',eco:'💰 Économie',social:'⚖️ Social',transport:'🚂 Transport'};
  tags.forEach(t=>{
    const b=document.createElement('button');
    b.className='tl-fbtn'+(tlFilter===t?' on':'');
    b.innerText=labels[t];
    b.onclick=()=>{tlFilter=t;buildTimeline();};
    fd.appendChild(b);
  });
  const items=timelineData.filter(e=>tlFilter==='all'||e.tag===tlFilter);
  const container=document.getElementById('tlItems');
  container.innerHTML='';
  items.forEach(e=>{
    const div=document.createElement('div');
    div.className='tl-item'+(e.important?' important':'');
    div.innerHTML=`
      <div class="tl-dot">${e.important?'★':''}</div>
      <div class="tl-tag ${e.tag}">${tagLabels[e.tag]||e.tag}</div>
      <div class="tl-date">${e.date}</div>
      <div class="tl-title">${e.title}</div>
      <div class="tl-desc">${e.desc}</div>`;
    div.onclick=()=>div.classList.toggle('open');
    container.appendChild(div);
  });
}

startFlash('all');
</script>
