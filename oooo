<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FlashHistoire</title>
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="FlashHistoire">
<link rel="apple-touch-icon" href="data:image/svg+xml;base64,">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{--bg:#0f0c29;--card:#1a1545;--accent:#ffd60a;--text:#f0eeff;--muted:#9b93cc;--r:18px;--green:#00dc78;--red:#ff3c50;}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;background-image:radial-gradient(ellipse at 20% 20%,#2d1b69 0%,transparent 50%),radial-gradient(ellipse at 80% 80%,#1a0a4a 0%,transparent 50%);}
header{padding:22px 18px 8px;display:flex;align-items:center;gap:12px;}
.logo-icon{width:44px;height:44px;background:var(--accent);border-radius:12px;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:22px;color:var(--bg);font-weight:900;box-shadow:0 4px 20px rgba(255,214,10,.35);flex-shrink:0;}
.logo-text{font-family:'Playfair Display',serif;font-size:22px;font-weight:700;}
.logo-text span{color:var(--accent);}
.container{padding:14px 16px 60px;max-width:680px;margin:auto;}
.hidden{display:none!important;}

/* NAV */
.nav{display:flex;gap:6px;overflow-x:auto;padding-bottom:4px;margin-bottom:18px;scrollbar-width:none;}
.nav::-webkit-scrollbar{display:none;}
.nav-btn{flex-shrink:0;background:rgba(255,255,255,.06);border:1.5px solid rgba(255,255,255,.1);border-radius:50px;padding:8px 16px;color:var(--muted);font-size:13px;font-weight:600;cursor:pointer;transition:all .18s;font-family:'DM Sans',sans-serif;}
.nav-btn.active{background:var(--accent);color:var(--bg);border-color:var(--accent);}

/* MENU */
.menu-title{font-family:'Playfair Display',serif;font-size:18px;font-weight:700;line-height:1.4;margin-bottom:22px;opacity:.9;}
.menu-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:22px;}
.menu-btn{background:var(--card);border:1.5px solid rgba(255,255,255,.08);border-radius:var(--r);padding:22px 14px;cursor:pointer;transition:transform .2s,border-color .2s,box-shadow .2s;text-align:center;color:var(--text);}
.menu-btn:hover{transform:translateY(-4px);border-color:var(--accent);box-shadow:0 8px 30px rgba(255,214,10,.15);}
.menu-btn .icon{font-size:30px;margin-bottom:7px;}
.menu-btn .label{font-size:15px;font-weight:600;}
.menu-btn .sublabel{font-size:12px;color:var(--muted);margin-top:2px;}
.section-title{font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:11px;}
.pill-row{display:flex;flex-wrap:wrap;gap:8px;}
.pill{background:rgba(255,255,255,.07);border:1.5px solid rgba(255,255,255,.1);border-radius:50px;padding:8px 18px;font-size:13px;font-weight:600;cursor:pointer;transition:all .18s;color:var(--text);font-family:'DM Sans',sans-serif;}
.pill:hover{background:rgba(255,214,10,.15);border-color:var(--accent);color:var(--accent);}
.pill.primary{background:var(--accent);color:var(--bg);border-color:var(--accent);}
.divider{height:1.5px;background:rgba(255,255,255,.07);margin:20px 0;}
.back-btn{background:transparent;border:none;color:var(--muted);font-size:13px;font-family:'DM Sans',sans-serif;cursor:pointer;display:flex;align-items:center;gap:6px;padding:0;margin-bottom:16px;transition:color .18s;}
.back-btn:hover{color:var(--text);}

/* FLASHCARDS */
.tab-row{display:flex;gap:7px;margin-bottom:16px;flex-wrap:wrap;}
.tab{padding:7px 14px;border-radius:9px;border:1.5px solid rgba(255,255,255,.1);background:transparent;color:var(--muted);font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;font-family:'DM Sans',sans-serif;}
.tab.active{background:var(--accent);color:var(--bg);border-color:var(--accent);}
.card-counter{text-align:center;font-size:13px;color:var(--muted);margin-bottom:14px;}
.card-wrap{width:100%;max-width:540px;height:220px;margin:0 auto 20px;perspective:1200px;cursor:pointer;}
.card-inner{position:relative;width:100%;height:100%;transition:transform .55s cubic-bezier(.4,0,.2,1);transform-style:preserve-3d;}
.card-wrap.flip .card-inner{transform:rotateY(180deg);}
.card-face{position:absolute;width:100%;height:100%;backface-visibility:hidden;border-radius:var(--r);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px;font-size:16px;line-height:1.5;box-shadow:0 16px 48px rgba(0,0,0,.4);}
.card-front{background:linear-gradient(135deg,#231863,#3a0ca3);border:1.5px solid rgba(255,255,255,.12);color:white;}
.card-front .hint{font-size:11px;color:rgba(255,255,255,.3);position:absolute;bottom:12px;}
.card-back{background:var(--accent);color:var(--bg);transform:rotateY(180deg);font-weight:600;font-size:15px;text-align:center;}
.cat-badge{position:absolute;top:11px;right:12px;font-size:11px;font-weight:700;letter-spacing:.8px;background:rgba(255,255,255,.15);border-radius:20px;padding:3px 9px;text-transform:uppercase;}

/* QUIZ */
.progress-track{height:6px;background:rgba(255,255,255,.1);border-radius:10px;margin-bottom:18px;overflow:hidden;}
.progress-fill{height:100%;background:var(--accent);border-radius:10px;transition:width .4s ease;width:0%;}
.quiz-num{font-size:12px;color:var(--muted);margin-bottom:12px;font-weight:600;}
.quiz-card{background:var(--card);border:1.5px solid rgba(255,255,255,.08);border-radius:var(--r);padding:22px;margin-bottom:14px;}
.quiz-q{font-size:16px;font-weight:600;line-height:1.45;margin-bottom:16px;}
.ans-btn{display:block;width:100%;background:rgba(255,255,255,.06);border:1.5px solid rgba(255,255,255,.1);border-radius:11px;padding:12px 15px;text-align:left;color:var(--text);font-size:14px;font-family:'DM Sans',sans-serif;cursor:pointer;margin-bottom:8px;transition:all .18s;font-weight:500;}
.ans-btn:hover:not(:disabled){border-color:var(--accent);background:rgba(255,214,10,.08);}
.ans-btn.correct{background:rgba(0,220,120,.15);border-color:var(--green);color:var(--green);}
.ans-btn.wrong{background:rgba(255,60,80,.15);border-color:var(--red);color:var(--red);}
.ans-btn:disabled{cursor:default;}
.result-box{background:var(--card);border-radius:var(--r);padding:28px 20px;text-align:center;border:1.5px solid rgba(255,255,255,.08);}
.result-score{font-family:'Playfair Display',serif;font-size:50px;font-weight:900;color:var(--accent);}
.result-label{font-size:20px;font-weight:700;margin:7px 0 3px;}
.result-sub{color:var(--muted);font-size:14px;margin-bottom:20px;}

/* TIMELINE */
.tl-filter{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:18px;}
.tl-fbtn{padding:7px 14px;border-radius:50px;border:1.5px solid rgba(255,255,255,.1);background:transparent;color:var(--muted);font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;font-family:'DM Sans',sans-serif;}
.tl-fbtn.on{background:rgba(255,255,255,.1);color:var(--text);border-color:rgba(255,255,255,.25);}
.timeline-wrap{position:relative;padding:6px 0 40px;}
.tl-line{position:absolute;left:26px;top:0;bottom:0;width:3px;background:linear-gradient(to bottom,#7b2ff7,var(--accent));border-radius:2px;}
.tl-item{position:relative;padding:0 0 26px 62px;cursor:pointer;}
.tl-dot{position:absolute;left:15px;top:5px;width:24px;height:24px;border-radius:50%;background:var(--bg);border:3px solid var(--accent);display:flex;align-items:center;justify-content:center;font-size:9px;transition:all .2s;z-index:1;}
.tl-item:hover .tl-dot{background:var(--accent);transform:scale(1.2);}
.tl-item.important .tl-dot{border-color:var(--accent);background:var(--accent);width:28px;height:28px;left:13px;}
.tl-date{font-size:12px;font-weight:700;color:var(--accent);margin-bottom:3px;letter-spacing:.4px;}
.tl-title{font-size:15px;font-weight:600;margin-bottom:4px;}
.tl-desc{font-size:13px;color:var(--muted);line-height:1.55;max-height:0;overflow:hidden;transition:max-height .35s ease,opacity .3s;opacity:0;}
.tl-item.open .tl-desc{max-height:250px;opacity:1;}
.tl-tag{display:inline-block;font-size:10px;font-weight:700;letter-spacing:.7px;padding:2px 8px;border-radius:20px;margin-bottom:4px;text-transform:uppercase;}
.tl-tag.eco{background:rgba(123,47,247,.3);color:#b893ff;}
.tl-tag.social{background:rgba(255,214,10,.2);color:var(--accent);}
.tl-tag.transport{background:rgba(255,100,50,.2);color:#ff9970;}
.tl-tag.politique{background:rgba(0,220,120,.2);color:var(--green);}
.tl-hint{font-size:12px;color:var(--muted);margin-bottom:16px;}
@media(max-width:420px){.menu-grid{grid-template-columns:1fr;}.card-face{font-size:14px;}}
</style>
</head>
<body>

<header>
  <div class="logo-icon">H</div>
  <div class="logo-text">Flash<span>Histoire</span></div>
</header>

<div class="container" style="padding-bottom:0;padding-top:8px;">
  <div class="nav">
    <button class="nav-btn active" onclick="showSection('menu')">🏠 Accueil</button>
    <button class="nav-btn" onclick="showSection('flashcards');startFlash('all')">🃏 Flashcards</button>
    <button class="nav-btn" onclick="showSection('quiz');startQuiz()">🎯 Quiz</button>
    <button class="nav-btn" onclick="showSection('frise')">📅 Frise</button>
  </div>
</div>

<!-- MENU -->
<div id="menu" class="container">
  <p class="menu-title">Industrialisation et transformations<br>économiques et sociales en France</p>
  <div class="menu-grid">
    <div class="menu-btn" onclick="showSection('flashcards');startFlash('all')">
      <div class="icon">🃏</div><div class="label">Flashcards</div><div class="sublabel">52 cartes</div>
    </div>
    <div class="menu-btn" onclick="showSection('quiz');startQuiz()">
      <div class="icon">🎯</div><div class="label">Quiz</div><div class="sublabel">30 questions</div>
    </div>
    <div class="menu-btn" onclick="showSection('frise')">
      <div class="icon">📅</div><div class="label">Frise</div><div class="sublabel">Interactive</div>
    </div>
    <div class="menu-btn" onclick="showSection('flashcards');startFlash('dates')">
      <div class="icon">⚡</div><div class="label">Dates clés</div><div class="sublabel">Révision rapide</div>
    </div>
  </div>
  <div class="divider"></div>
  <p class="section-title">Par thème</p>
  <div class="pill-row">
    <button class="pill" onclick="showSection('flashcards');startFlash('dates')">📅 Dates</button>
    <button class="pill" onclick="showSection('flashcards');startFlash('notions')">📖 Notions</button>
    <button class="pill" onclick="showSection('flashcards');startFlash('acteurs')">👤 Acteurs</button>
    <button class="pill" onclick="showSection('flashcards');startFlash('social')">⚖️ Social</button>
    <button class="pill" onclick="showSection('flashcards');startFlash('rural')">🌾 Rural</button>
  </div>
</div>

<!-- FLASHCARDS -->
<div id="flashcards" class="container hidden">
  <button class="back-btn" onclick="showSection('menu')">← Retour</button>
  <div class="tab-row">
    <button class="tab" onclick="startFlash('all')">Toutes</button>
    <button class="tab" onclick="startFlash('dates')">Dates</button>
    <button class="tab" onclick="startFlash('notions')">Notions</button>
    <button class="tab" onclick="startFlash('acteurs')">Acteurs</button>
    <button class="tab" onclick="startFlash('social')">Social</button>
    <button class="tab" onclick="startFlash('rural')">Rural</button>
  </div>
  <div class="card-counter" id="cardCounter"></div>
  <div class="card-wrap" id="flashCard" onclick="flipCard()">
    <div class="card-inner">
      <div class="card-face card-front">
        <span class="cat-badge" id="catBadge"></span>
        <div id="question"></div>
        <span class="hint">Toucher pour retourner</span>
      </div>
      <div class="card-face card-back" id="answer"></div>
    </div>
  </div>
  <div class="pill-row" style="justify-content:center">
    <button class="pill" onclick="prevCard()">← Préc.</button>
    <button class="pill primary" onclick="nextCard()">Suivante →</button>
  </div>
</div>

<!-- QUIZ -->
<div id="quiz" class="container hidden">
  <button class="back-btn" onclick="showSection('menu')">← Retour</button>
  <div class="progress-track"><div class="progress-fill" id="progress"></div></div>
  <div class="quiz-num" id="quizNum"></div>
  <div id="quizContent"></div>
</div>

<!-- FRISE -->
<div id="frise" class="container hidden">
  <button class="back-btn" onclick="showSection('menu')">← Retour</button>
  <p style="font-family:'Playfair Display',serif;font-size:19px;font-weight:700;margin-bottom:4px;">Frise chronologique</p>
  <p class="tl-hint">Clique sur un événement pour afficher le détail ↓</p>
  <div class="tl-filter" id="tlFilter"></div>
  <div class="timeline-wrap">
    <div class="tl-line"></div>
    <div id="tlItems"></div>
  </div>
</div>

<script>
const allCards=[
  // NOTIONS
  {cat:'notions',q:"Définition : Industrialisation",a:"Processus de transformation économique marqué par le développement des industries et de la production mécanisée."},
  {cat:'notions',q:"Définition : Exode rural",a:"Départ massif des populations rurales vers les villes industrielles, accéléré par la mécanisation agricole."},
  {cat:'notions',q:"Définition : Capitalisme industriel",a:"Système économique basé sur l'investissement de capitaux privés pour produire et réaliser un profit."},
  {cat:'notions',q:"Définition : Urbanisation",a:"Processus d'augmentation de la population dans les villes, lié à l'industrialisation et à l'exode rural."},
  {cat:'notions',q:"Définition : Libéralisme économique",a:"Doctrine prônant la liberté d'entreprendre, la libre concurrence et la non-intervention de l'État dans l'économie."},
  {cat:'notions',q:"Qu'est-ce que le saint-simonisme ?",a:"Courant de pensée du XIXe s. prônant le progrès industriel, scientifique et technologique au service de l'humanité."},
  {cat:'notions',q:"Qu'est-ce qu'un syndicat ?",a:"Organisation collective de travailleurs défendant leurs droits, salaires et conditions de travail face aux patrons."},
  {cat:'notions',q:"Qu'est-ce que la mécanisation des usines ?",a:"Remplacement du travail manuel par des machines, augmentant la productivité mais transformant les conditions de travail."},
  {cat:'notions',q:"Bourgeoisie : quelles sous-catégories ?",a:"Grande bourgeoisie (grands patrons, banquiers), moyenne bourgeoisie (petits patrons, médecins), petite bourgeoisie (boutiquiers, notaires)."},
  {cat:'notions',q:"Qu'est-ce que la société de consommation naissante ?",a:"Phénomène du XIXe s. où les grands magasins (Au Bon Marché) proposent tout au même endroit, standardisent la consommation et concurrencent les petits commerces."},
  // SOCIAL
  {cat:'social',q:"Conditions de vie ouvrière au XIXe s.",a:"Journées de 12 à 15h, salaires bas, travail dangereux, logements insalubres (corons), absence de protection sociale, travail des enfants dès 8 ans."},
  {cat:'social',q:"Qu'est-ce qu'un 'coron' ?",a:"Logement ouvrier rudimentaire, souvent insalubre, situé près des usines ou des mines, plusieurs personnes par pièce."},
  {cat:'social',q:"Loi de 1841 : que dit-elle ?",a:"Première loi sociale en France : interdit le travail des moins de 8 ans, limite à 8h/jour pour les 8-12 ans. Reste peu respectée faute de contrôle."},
  {cat:'social',q:"Loi de 1864 : que dit-elle ?",a:"Légalisation du droit de grève en France sous Napoléon III. Les ouvriers peuvent cesser le travail collectivement sans être poursuivis pénalement."},
  {cat:'social',q:"Loi Waldeck-Rousseau (1884) : que dit-elle ?",a:"Liberté syndicale complète en France. Les syndicats ouvriers peuvent se constituer librement et défendre leurs membres."},
  {cat:'social',q:"Revendications ouvrières au XIXe s.",a:"Augmentation des salaires, journée de 8h, suppression du travail des enfants, reconnaissance des syndicats, amélioration des conditions de sécurité."},
  {cat:'social',q:"Pourquoi Napoléon III accorde-t-il le droit de grève en 1864 ?",a:"Calcul politique : il espère attirer le soutien ouvrier. Mais il ne soutient pas vraiment les travailleurs → les ouvriers se tournent vers les républicains."},
  {cat:'social',q:"Mode de vie bourgeois au XIXe s.",a:"Voyages, résidences secondaires, éducation des enfants (romans/musique pour les filles, voyages pour les garçons), soirées mondaines et bals comme centre de la vie sociale."},
  {cat:'social',q:"Que dénonce Zola dans Germinal (1885) ?",a:"Conditions des mineurs : chaleur à 35°C, danger permanent, gaz asphyxiants, salaires insuffisants, conflits violents avec les patrons. L'ouvrier est traité comme un enfant sans droits."},
  {cat:'social',q:"Que décrit Zola dans Au Bonheur des Dames (1883) ?",a:"La naissance des grands magasins : tout vendu au même endroit, employés bien traités mais surveillés. Début de la société de consommation. Ruine des petits commerces."},
  {cat:'social',q:"Tensions sociales : causes principales",a:"Inégalités criantes entre bourgeoisie (riche, oisive) et ouvriers (pauvres, exploités). Les ouvriers ressentent une injustice fondamentale qui nourrit les grèves et les mouvements sociaux."},
  // ACTEURS
  {cat:'acteurs',q:"James Watt",a:"Ingénieur écossais (1736-1819). Perfectionne la machine à vapeur vers 1765-1782, moteur essentiel de la révolution industrielle."},
  {cat:'acteurs',q:"Émile Zola",a:"Écrivain naturaliste français (1840-1902). Décrit la société industrielle dans Germinal (mineurs, 1885) et Au Bonheur des Dames (grands magasins, 1883)."},
  {cat:'acteurs',q:"Les Frères Pereire",a:"Grands banquiers saint-simoniens. Issus de la bourgeoisie, ils créent le Crédit mobilier et financent les chemins de fer, rassemblant les capitaux de la bourgeoisie moyenne et haute."},
  {cat:'acteurs',q:"George Stephenson",a:"Ingénieur anglais pionnier du chemin de fer. Crée la première locomotive à vapeur commerciale (1825), révolutionnant les transports."},
  {cat:'acteurs',q:"Haussmann (Baron)",a:"Préfet de Paris sous Napoléon III. Rénove Paris : grands boulevards, égouts, parcs. 600 000 ouvriers mobilisés. Les plus pauvres repoussés vers la périphérie ou d'autres villes."},
  {cat:'acteurs',q:"Napoléon III et l'industrialisation",a:"Soutient activement l'industrie : chemins de fer, traité de libre-échange avec l'Angleterre (1860), rénovation de Paris. Incarne la modernisation économique de la France."},
  // RURAL
  {cat:'rural',q:"Transformations agricoles au XIXe s.",a:"Mécanisation (moissonneuses, batteuses), usage d'engrais chimiques, amélioration des semences, augmentation des rendements. La France reste pourtant plus rurale que l'Angleterre."},
  {cat:'rural',q:"Impact du chemin de fer sur les campagnes",a:"Désenclave les villages, accélère le transport des marchandises, augmente les revenus des agriculteurs, favorise l'exode rural vers les villes industrielles."},
  {cat:'rural',q:"Pourquoi la France industrialise-t-elle plus lentement ?",a:"Manque d'investisseurs, agriculture encore dominante, économie paysanne peu productive, moins de charbon qu'en Angleterre, structure sociale peu favorable aux risques industriels."},
  {cat:'rural',q:"Comment l'État intervient-il dans les campagnes ?",a:"Finance les infrastructures (routes, voies ferrées), encourage la mécanisation, développe la politique sanitaire et l'instruction publique."},
  {cat:'rural',q:"Qu'est-ce que la mécanisation agricole ?",a:"Introduction de machines (moissonneuses, batteuses à vapeur) dans l'agriculture, libérant de la main-d'oeuvre qui part vers les usines."},
  // DATES
  {cat:'dates',q:"Fin XVIIIe siècle",a:"Début de la 1ère révolution industrielle en Angleterre : machine à vapeur, mines, premières usines."},
  {cat:'dates',q:"1760-1782",a:"James Watt perfectionne la machine à vapeur."},
  {cat:'dates',q:"~1825",a:"George Stephenson : première locomotive à vapeur commerciale en Angleterre."},
  {cat:'dates',q:"~1850",a:"Accélération de l'industrialisation en France. Environ 3 000 km de voies ferrées."},
  {cat:'dates',q:"1841",a:"Première loi sociale en France : restriction du travail des enfants dans les usines."},
  {cat:'dates',q:"1853-1869",a:"Travaux haussmanniens à Paris : 600 000 ouvriers, rénovation totale de la capitale sous Napoléon III."},
  {cat:'dates',q:"1860",a:"Traité de libre-échange avec l'Angleterre. La photographie couvre presque toute la France."},
  {cat:'dates',q:"1864",a:"Légalisation du droit de grève en France (Napoléon III)."},
  {cat:'dates',q:"~1870",a:"17 000 km de voies ferrées en France. Le réseau ferroviaire est multiplié par 5 en 20 ans."},
  {cat:'dates',q:"1883",a:"Zola publie Au Bonheur des Dames : naissance des grands magasins, début de la société de consommation."},
  {cat:'dates',q:"1884",a:"Loi Waldeck-Rousseau : liberté syndicale complète en France."},
  {cat:'dates',q:"1885",a:"Zola publie Germinal : description de la misère des mineurs du Nord de la France."},
  {cat:'dates',q:"Fin XIXe s.",a:"La France est la 4e puissance industrielle mondiale. Transition économique achevée."},
];

const quizData=[
  {q:"Quel pays est pionnier de la révolution industrielle ?",answers:["Angleterre","France","Allemagne","Italie"],correct:"Angleterre"},
  {q:"Quelle énergie alimente principalement les machines au XIXe s. ?",answers:["Charbon","Pétrole","Électricité","Bois"],correct:"Charbon"},
  {q:"Quel phénomène correspond au départ massif des paysans vers les villes ?",answers:["Exode rural","Migration coloniale","Urbanisme planifié","Nomadisme"],correct:"Exode rural"},
  {q:"Quelle doctrine prône la non-intervention de l'État dans l'économie ?",answers:["Libéralisme économique","Socialisme","Communisme","Mercantilisme"],correct:"Libéralisme économique"},
  {q:"Quel transport révolutionne l'économie au XIXe s. ?",answers:["Chemin de fer","Diligence","Canal","Navigation à voile"],correct:"Chemin de fer"},
